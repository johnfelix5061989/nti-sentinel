# Configurações do NTI Sentinel
# Copie este arquivo para .env e ajuste os valores

# Ambiente: production ou development
NODE_ENV=development

# Porta do servidor
PORT=3000

# Secret da sessão (USE uma string aleatória longa em produção!)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=trocar-esta-string-por-um-secret-aleatorio

# Caminho do banco SQLite
DB_PATH=./database.sqlite

# Credenciais do Dev inicial (criado apenas no primeiro boot)
ADMIN_USER=admin
ADMIN_SENHA=nti2026
